{
  "manifest_version": 3,
  "name": "IP定位与本地代理",
  "version": "1.1",
  "description": "基于IP位置自动更新浏览器的GPS位置，并支持手动配置本地浏览器代理。",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "proxy",
    "privacy",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["main_spoof.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "sandbox": {
    "pages": [
      "map.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; child-src 'none'; object-src 'none'"
  },
  "web_accessible_resources": [{
    "resources": ["map.html", "images/*.svg"],
    "matches": ["<all_urls>"]
  }]
}
