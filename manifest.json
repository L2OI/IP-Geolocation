{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.3",
  "default_locale": "zh_CN",
  "description": "__MSG_extDescription__",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "proxy",
    "privacy",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "sandbox": {
    "pages": [
      "map.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; child-src 'none'; object-src 'none'"
  },
  "web_accessible_resources": [{
    "resources": ["map.html", "images/*.svg"],
    "matches": ["<all_urls>"]
  }]
}
